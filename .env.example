# Discord
# Optional for the Seerr issue workflow; set both to enable direct Discord channel chat.
DISCORD_TOKEN=
DISCORD_GUILD_ID=
INSTANCE_OWNER_DISCORD_ID=

# Agent entrypoints
# Enables listening to normal messages in one Discord channel. Requires Discord Message Content intent.
AGENT_DISCORD_CHANNEL_ID=
# Small model used to decide whether non-mention channel messages should open a support thread.
AGENT_DISCORD_TRIAGE_MODEL=gpt-5.4-mini
AGENT_DISCORD_TRIAGE_REASONING_EFFORT=none
AGENT_DISCORD_TRIAGE_THRESHOLD=0.75
AGENT_DISCORD_THREAD_ARCHIVE_MINUTES=1440
AGENT_DISCORD_CONTEXT_RECENT_MESSAGES=12
# Empty listen addr disables the local Seerr webhook server.
SEERR_WEBHOOK_LISTEN_ADDR=127.0.0.1:8080
SEERR_WEBHOOK_PATH=/webhooks/seerr
# Optional shared secret. Send as Authorization: Bearer <secret> or X-Blitzcrank-Webhook-Secret.
SEERR_WEBHOOK_SECRET=

# Jellyfin
JELLYFIN_BASE_URL=
JELLYFIN_API_KEY=

# Seerr
SEERR_BASE_URL=
SEERR_API_KEY=
# Optional Jellyseerr user id to attribute issue comments to a dedicated bot user.
SEERR_BOT_USER_ID=
SEERR_BOT_DISPLAY_NAME=blitzcrank

# Sonarr
SONARR_BASE_URL=
SONARR_API_KEY=

# Radarr
RADARR_BASE_URL=
RADARR_API_KEY=

# SABnzbd and read-only filesystem diagnostics
SABNZBD_BASE_URL=
SABNZBD_API_KEY=
# Comma-separated absolute roots the agent may inspect with read-only filesystem tools.
FS_TOOL_ALLOWED_ROOTS=

# Optional web search tool, backed by Exa Search API.
EXA_API_KEY=
EXA_BASE_URL=https://api.exa.ai

# LLM provider
# openai-compatible supports OpenAI, OpenRouter, and any /chat/completions-compatible API.
# codex-oauth uses `blitzcrank codex login` credentials and the Codex subscription route.
LLM_PROVIDER=openai-compatible
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
# Default model for agent runs.
MODEL=gpt-5.5
# Optional override for reasoning-capable models: minimal, low, medium, high.
# Leave empty to use Blitzcrank's curated model defaults.
REASONING_EFFORT=
CODEX_AUTH_PROFILE=default
CODEX_AUTH_STORE=
CODEX_BASE_URL=https://chatgpt.com/backend-api/codex
# Codex OAuth only. Keep standard for background webhooks; set fast for lower latency and higher quota use.
CODEX_SERVICE_TIER=standard
AGENT_THREADS_DIR=threads
AGENT_MAX_TOOL_ITERATIONS=15
AGENT_RUN_TIMEOUT=5m
CRON_ENABLED=false
# Optional comma-separated directories of additional markdown automation definitions.
AUTOMATIONS_EXTRA_DIRS=
OPENROUTER_HTTP_REFERER=
OPENROUTER_X_TITLE=blitzcrank

# Local development database
DATABASE_PATH=./blitzcrank.sqlite

# Bot/runtime
BOT_PUBLIC_NAME=blitzcrank
TIMEZONE=Europe/Vienna
