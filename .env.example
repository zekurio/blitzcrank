# Optional: point Blitzcrank at a different TOML config file.
# Keep normal runtime settings in blitzcrank.toml; .env is for bootstrap
# paths and deliberate local overrides.
BLITZCRANK_CONFIG=./blitzcrank.toml

# Optional secret overrides. You can also put these in TOML if your
# deployment manages the TOML securely.
DISCORD_TOKEN=
DISCORD_GUILD_ID=
DISCORD_AUTOMATION_CHANNEL_ID=
# Comma-separated Discord channel snowflakes watched by the conversational agent.
DISCORD_WATCHED_CHANNEL_IDS=
DISCORD_TRIAGE_TIMEOUT=8s
# Leave unset to inherit AGENT_RUN_TIMEOUT.
DISCORD_RUN_TIMEOUT=
DISCORD_DEBOUNCE=750ms
DISCORD_THREAD_INACTIVITY=24h
DISCORD_RETENTION=720h
DISCORD_MUTATION_BUDGET=3
BOT_PUBLIC_NAME=
BLITZCRANK_HTTP_LISTEN_ADDR=
SEERR_API_KEY=
JELLYFIN_API_KEY=
TMDB_API_TOKEN=
DIGESTS_ENABLED=false
DIGEST_DEFAULT_REGION=US
DIGEST_DISPATCH_SCHEDULE=@every 1m
DIGEST_MAX_ITEMS=12
DIGEST_RETRY_DELAY=15m
SONARR_API_KEY=
RADARR_API_KEY=
SABNZBD_API_KEY=
ANVIL_SYSTEMD_UNIT=anvil.service
KAGI_API_KEY=
OPENAI_API_KEY=
OPENAI_AUTH=
OPENROUTER_API_KEY=
EXA_API_KEY=
SEERR_WEBHOOK_SECRET=
CACHE_DIR=

# Optional Pi source-model map, for example:
# PI_MODELS={"default":"provider/model","discord_triage":"provider/fast-model","discord":"provider/model","review":"provider/reviewer"}
PI_MODELS=
REVIEW_TIMEOUT=15s
REVIEW_CAPACITY=1
CONFIRMATION_TTL=15m
SEERR_MUTATION_BUDGET=5
AUTOMATION_MUTATION_BUDGET=5

# Codex OAuth credentials are managed with `blitzcrank codex login`.
CODEX_AUTH_PROFILE=default
CODEX_AUTH_STORE=
