# Optional: point Blitzcrank at a different TOML config file.
BLITZCRANK_CONFIG=./blitzcrank.toml

# Keep secrets here or inject them from your service manager.
DISCORD_TOKEN=
SEERR_API_KEY=
JELLYFIN_API_KEY=
SONARR_API_KEY=
RADARR_API_KEY=
SABNZBD_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=
EXA_API_KEY=
SEERR_WEBHOOK_SECRET=

# Codex OAuth credentials are managed with `blitzcrank codex login`.
CODEX_AUTH_PROFILE=default
CODEX_AUTH_STORE=
