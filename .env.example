# Discord
# Optional for the Seerr issue workflow; set both to enable direct Discord channel chat.
DISCORD_TOKEN=
DISCORD_GUILD_ID=
INSTANCE_OWNER_DISCORD_ID=

# Agent entrypoints
# Enables listening to normal messages in one Discord channel. Requires Discord Message Content intent.
DISCORD_CHANNEL_ID=
DISCORD_TRIAGE_THRESHOLD=0.75
DISCORD_THREAD_ARCHIVE_MINUTES=1440
DISCORD_CONTEXT_RECENT_MESSAGES=12
# Set a listen addr such as 127.0.0.1:8080 to enable the local Seerr webhook server.
# Enabling the webhook requires SEERR_BASE_URL and SEERR_API_KEY.
SEERR_WEBHOOK_LISTEN_ADDR=
SEERR_WEBHOOK_PATH=/webhooks/seerr
# Optional shared secret. Send as Authorization: Bearer <secret> or X-Blitzcrank-Webhook-Secret.
SEERR_WEBHOOK_SECRET=

# Jellyfin
JELLYFIN_BASE_URL=
JELLYFIN_API_KEY=

# Seerr
SEERR_BASE_URL=
SEERR_API_KEY=
# Optional Jellyseerr user id to attribute issue comments to a dedicated bot user.
SEERR_BOT_USER_ID=
SEERR_BOT_DISPLAY_NAME=blitzcrank
# Optional JSON object mapping Discord user ids to Seerr user ids for requester-aware Discord flows.
# Seerr's own Discord Benutzer ID field is used automatically when available; this map acts as an override/fallback.
# Example: {"123456789012345678":"4","234567890123456789":"7"}
DISCORD_SEERR_USER_MAP=

# Sonarr
SONARR_BASE_URL=
SONARR_API_KEY=

# Radarr
RADARR_BASE_URL=
RADARR_API_KEY=

# SABnzbd and read-only filesystem diagnostics
SABNZBD_BASE_URL=
SABNZBD_API_KEY=
# Comma-separated absolute roots the agent may inspect with read-only filesystem tools.
FS_TOOL_ALLOWED_ROOTS=

# Optional web search tool, backed by Exa Search API.
EXA_API_KEY=
EXA_BASE_URL=https://api.exa.ai

# LLM providers
# openai-compatible supports OpenAI and generic /chat/completions-compatible APIs.
# openrouter uses OpenRouter-specific request shaping, headers, errors, and defaults.
# codex-oauth uses `blitzcrank codex login` credentials and the Codex subscription route.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_HTTP_REFERER=
OPENROUTER_X_TITLE=blitzcrank
CODEX_AUTH_PROFILE=default
CODEX_AUTH_STORE=
CODEX_BASE_URL=https://chatgpt.com/backend-api/codex
# Codex OAuth only. Fast mode lowers latency and uses higher quota.
CODEX_FAST_MODE=false

# Runtime profiles. Provider values are openai-compatible, openrouter, or codex-oauth.
# Optional reasoning override for reasoning-capable models: minimal, low, medium, high.
# Examples: route automations through OpenRouter and Jellyseerr through Codex OAuth.
AGENT_DEFAULT_PROVIDER=openai-compatible
AGENT_DEFAULT_MODEL=gpt-5.5
AGENT_DEFAULT_REASONING_EFFORT=
AGENT_SEERR_PROVIDER=
AGENT_SEERR_MODEL=
AGENT_SEERR_REASONING_EFFORT=
AGENT_DISCORD_PROVIDER=
AGENT_DISCORD_MODEL=
AGENT_DISCORD_REASONING_EFFORT=
AGENT_AUTOMATION_PROVIDER=
AGENT_AUTOMATION_MODEL=
AGENT_AUTOMATION_REASONING_EFFORT=
AGENT_DISCORD_TRIAGE_PROVIDER=
AGENT_DISCORD_TRIAGE_MODEL=
AGENT_DISCORD_TRIAGE_REASONING_EFFORT=
AGENT_THREADS_DIR=threads
RUNTIME_CONFIG_PATH=./runtime-config.json
AGENT_MAX_TOOL_ITERATIONS=15
AGENT_RUN_TIMEOUT=5m
AUTOMATIONS_ENABLED=false
# Runtime Markdown directories.
SKILLS_DIR=skills
AUTOMATIONS_DIR=automations
# Optional comma-separated directories of additional markdown automation definitions.
AUTOMATIONS_EXTRA_DIRS=

# Local development database
DATABASE_PATH=./blitzcrank.sqlite

# Bot/runtime
BOT_PUBLIC_NAME=blitzcrank
TIMEZONE=Europe/Vienna
