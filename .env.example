# Optional: point Blitzcrank at a different TOML config file.
# Keep normal runtime settings in blitzcrank.toml; .env is for bootstrap
# paths and deliberate local overrides.
BLITZCRANK_CONFIG=./blitzcrank.toml

# Optional secret overrides. You can also put these in TOML if your
# deployment manages the TOML securely.
DISCORD_TOKEN=
DISCORD_ADMIN_ROLE_ID=
SEERR_API_KEY=
JELLYFIN_API_KEY=
SONARR_API_KEY=
RADARR_API_KEY=
SABNZBD_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=
EXA_API_KEY=
SEERR_WEBHOOK_SECRET=

# Codex OAuth credentials are managed with `blitzcrank codex login`.
CODEX_AUTH_PROFILE=default
CODEX_AUTH_STORE=
